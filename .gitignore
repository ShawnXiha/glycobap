memory/*.pkl
memory/*.db

# ------------------------------------------------------------
# Artifacts (large generated files)
# ------------------------------------------------------------
artifacts/*.pdb
artifacts/*.cif
artifacts/*.mol2
artifacts/*.sdf

# ------------------------------------------------------------
# Specific Large Files
# ------------------------------------------------------------
# Any file larger than 50MB (typical GitHub limit)
# These patterns catch common large file types
*.mp4
*.avi
*.mov
*.wmv
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
