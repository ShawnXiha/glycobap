*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# ------------------------------------------------------------
# AlphaFold 3 - Large Files
# ------------------------------------------------------------
# AF3 source code (downloaded separately)
alphafold3/

# AF3 model parameters (several GB)
models/
*.ckpt
*.pth
*.pt

# AF3 output files (large)
results/af3_output/
results/af3_output/**/

# AF3 database cache
public_databases/
*.pdb
*.cif
*.mmcif
*.fasta
*.a3m

# Chemical component cache
*.pickle
*.pkl
chemical_component_sets.pickle

# ------------------------------------------------------------
# Large Data Files
# ------------------------------------------------------------
# Benchmark data
data/benchmark_structures_full.json
data/*.json

# GlyTouCan database (large)
glytoucan_database/

# Large intermediate files
*.db
*.sqlite
*.h5
*.hdf5

# ------------------------------------------------------------
# AF3 Input Files (keep small test files)
# ------------------------------------------------------------
# Keep validation input files, ignore large outputs
# results/af3_validation/*.json  # Keep these
results/af3_output/**/
results/af3_analysis/**/

